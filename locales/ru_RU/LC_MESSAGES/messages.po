#: core/text_manager/texts.py:286
msgid ""
"<b>🤝 Affiliate Program</b>\n"
"\n"
"🏆 Rewards under the referral (affiliate) \n"
"program are divided into two levels:\n"
"├  For users who joined via your link — Level 1 referrals\n"
"└  For users who joined via your referrals' links — Level 2 referrals\n"
"🤑 How much can you earn?\n"
"├  For a Level 1 referral: {level_one_percents}%\n"
"└  For a Level 2 referral: {level_two_percents}%\n"
"\n"
"🥇 Statistics:\n"
"├  Total earned: {total_bonus_amount}\n"
"└  Personally invited: {referrals_count}\n"
"\n"
"🎁 Registration Bonus:\n"
"└  For every user who activates the bot via your referral \n"
"link, via your check, or via a bot that you created, you also \n"
"receive {bonus_amount} rubles.\n"
"\n"
"⤵️ Your Links:\n"
"└ https://t.me/{bot_username}?start=ref_{user_id}\n"
msgstr ""

